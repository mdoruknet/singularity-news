# Bu dosyayı ".env" olarak kopyalayın ve değerleri doldurun.
# cp .env.example .env

# Çeviri sağlayıcısı: "gemini" (varsayılan) veya "anthropic".
LLM_PROVIDER=gemini

# Google Gemini API anahtarı — https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...
# (İsteğe bağlı) Gemini model adı
# GEMINI_MODEL=gemini-2.5-flash

# Anthropic Claude API anahtarı (yalnızca LLM_PROVIDER=anthropic ise gerekir)
# https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# (İsteğe bağlı) SQLite veritabanı yolu
SINGULARITY_DB=singularity.db

# CORS: izin verilen frontend kaynakları (virgülle ayrılmış). Boşsa yerel varsayılan.
# Örn: https://singularity.vercel.app
ALLOWED_ORIGINS=
