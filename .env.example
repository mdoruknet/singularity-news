# docker-compose bu dosyayı (.env olarak) otomatik okur.
# cp .env.example .env

# Anthropic Claude API anahtarı — backend ve scheduler kullanır.
ANTHROPIC_API_KEY=sk-ant-...

# Frontend derlemesine gömülecek API adresi.
# Yerel compose için varsayılan yeterlidir; production'da gerçek backend URL'i girin.
VITE_API_URL=http://localhost:8000

# CORS: backend'in kabul edeceği kaynaklar (virgülle ayrılmış).
# Boş bırakılırsa güvenli yerel varsayılanlara düşülür.
# Örn: https://singularity.vercel.app,https://www.example.com
ALLOWED_ORIGINS=
